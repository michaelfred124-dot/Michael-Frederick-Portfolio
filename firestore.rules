rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 200
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 200
        && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.message is string && data.message.size() >= 1 && data.message.size() <= 2000
        && data.createdAt == request.time;
    }

    // Messages collection
    match /messages/{messageId} {
      // Allow creation of messages with strict validation
      allow create: if isValidMessage(request.resource.data);
      
      // Deny read, update, delete from client (only accessible via console)
      allow get, list, update, delete: if false;
    }
  }
}
